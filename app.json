{
  "expo": {
    "name": "Stim Check",
    "slug": "stim-check",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/prefixlogowhite.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/prefixlogowhite.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stimcheck.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/prefixlogowhite.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.stimcheck.app"
    },
    "web": {
      "favicon": "./assets/prefixlogowhite.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "35278daa-6744-4f46-9950-a38465a1a7e5"
      }
    },
    "owner": "eddienep"
  }
}
